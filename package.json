{
  "name": "webgame01",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "concurrently -k -n worker,web -c blue,green \"pnpm dev:worker\" \"pnpm dev:web\"",
    "dev:worker": "wrangler dev",
    "dev:web": "pnpm --filter @sengoku/web dev",
    "build": "pnpm --filter @sengoku/web build",
    "test": "pnpm -r test",
    "e2e": "pnpm --filter @sengoku/web e2e",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "pnpm -r typecheck",
    "core:test": "pnpm --filter @sengoku/core test",
    "core:headless": "pnpm --filter @sengoku/core headless"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.20.0"
  }
}
